{
  "name": "aiyu-multi-agent",
  "version": "2.2.4",
  "description": "Production-grade AI Agent Platform — 83 Agents, 46 Skills, 78 Workflows, Smart Init, Plugin System, Agent Testing, Publishing",
  "bin": {
    "aiyu-multi-agent": "./bin/cli.js"
  },
  "scripts": {
    "checklist": "python3 .windsurf/scripts/checklist.py .",
    "checklist:url": "python3 .windsurf/scripts/checklist.py . --url http://localhost:3000",
    "security": "python3 .windsurf/skills/vulnerability-scanner/scripts/security_scan.py .",
    "lint": "python3 .windsurf/skills/lint-and-validate/scripts/lint_runner.py .",
    "test": "python3 .windsurf/skills/testing-patterns/scripts/test_runner.py .",
    "ux": "python3 .windsurf/skills/frontend-design/scripts/ux_audit.py .",
    "seo": "python3 .windsurf/skills/seo-fundamentals/scripts/seo_checker.py .",
    "schema": "python3 .windsurf/skills/database-design/scripts/schema_validator.py .",
    "postinstall": "node ./bin/postinstall.js"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "glob": "^10.3.16",
    "inquirer": "^9.2.23",
    "ora": "^5.4.1",
    "tweetsodium": "^0.0.4",
    "yaml": "^2.4.1"
  },
  "keywords": [
    "aiyu-multi-agent",
    "ai-agent",
    "agent-framework",
    "cli",
    "agent-forge",
    "multi-agent",
    "orchestration",
    "automation",
    "developer-tools",
    "agent-platform",
    "agent-testing",
    "plugin-system"
  ],
  "author": "teeprakorn1 <https://github.com/teeprakorn1>",
  "contributors": [
    "FrameHandsomez <https://github.com/FrameHandsomez>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teeprakorn1/aiyu-multi-agent.git"
  },
  "bugs": {
    "url": "https://github.com/teeprakorn1/aiyu-multi-agent/issues"
  },
  "homepage": "https://github.com/teeprakorn1/aiyu-multi-agent#readme",
  "files": [
    ".windsurf/",
    "bin/",
    "lib/",
    "templates/",
    "LICENSE",
    "README.md",
    "CODEBASE.md",
    ".windsurfrules"
  ],
  "engines": {
    "node": ">=16.0.0"
  }
}